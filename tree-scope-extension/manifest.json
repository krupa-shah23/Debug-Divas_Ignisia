{
  "manifest_version": 3,
  "name": "TreeScope Overlay",
  "version": "1.0",
  "description": "Urban tree-planting recommendation system overlay for Google Maps.",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*"],
      "css": ["content/content.css"],
      "js": ["content/content.js"]
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
